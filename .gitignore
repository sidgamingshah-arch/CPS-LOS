# Java / Maven
target/
*.class
*.jar
*.war
!.mvn/wrapper/maven-wrapper.jar
.mvn/timing.properties

# SQLite databases (created at runtime)
data/
*.db
*.db-journal
*.sqlite
*.sqlite3

# Node / React
node_modules/
frontend/dist/
frontend/.vite/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# IDE
.idea/
*.iml
.vscode/
.settings/
.project
.classpath

# OS
.DS_Store
Thumbs.db

# Logs / env
*.log
.env
.env.local

# Local LLM config override (keep a filled-in copy — with a real endpoint/key — out of git).
# The committed config/llm.yml reads the API key from HELIX_LLM_API_KEY, so it holds no secret.
config/*.local.yml

# TS build info
frontend/tsconfig.tsbuildinfo

# Python bytecode (e2e scripts + orchestrator)
__pycache__/
*.pyc
*.pyo

# Claude Code transient agent worktrees (per-session isolation scaffolding)
.claude/worktrees/
